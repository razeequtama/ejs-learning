<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= blog.title %></title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <h1><%= blog.title %></h1>

    <div>
        <% blog.content.forEach(paragraph => { %>
            <p><%= paragraph %></p>
        <% }) %>
    </div>

    <a href="/blogs">Back to all blogs</a>
</body>
</html>